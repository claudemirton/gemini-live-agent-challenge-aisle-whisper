# ── choose ONE auth path ────────────────────────────────────────────────────────

# (A) Developer API key (simple local dev)
GOOGLE_API_KEY=__your_gemini_api_key__

# (B) Vertex AI (recommended for prod / Cloud Run)
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_LOCATION=us-east4
# If running locally with a service account json:
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/sa-key.json

# ── common ─────────────────────────────────────────────────────────────────────
PORT=8080
GEMINI_MODEL=gemini-3-flash-preview    # low-latency streaming
GEMINI_MODEL_DEEP=gemini-3-pro-preview # deeper planning / artifact generation

# CORS (frontend dev URL)
CORS_ORIGIN=http://localhost:5173
