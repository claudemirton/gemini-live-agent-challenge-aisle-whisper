{
  "name": "aw-pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "VITE_BACKEND_WS_URL=${VITE_BACKEND_WS_URL:?set VITE_BACKEND_WS_URL} VITE_BACKEND_API_URL=${VITE_BACKEND_API_URL:?set VITE_BACKEND_API_URL} npm run build",
    "build:prod-with-debug": "VITE_SHOW_OVERLAY_DEBUG=true VITE_BACKEND_WS_URL=${VITE_BACKEND_WS_URL:?set VITE_BACKEND_WS_URL} VITE_BACKEND_API_URL=${VITE_BACKEND_API_URL:?set VITE_BACKEND_API_URL} npm run build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.9",
    "vite-plugin-pwa": "^1.1.0",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "sharp-ico": "^0.1.5"
  }
}
